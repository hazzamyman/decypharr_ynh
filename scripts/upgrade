#!/bin/bash
source _common.sh
source /usr/share/yunohost/helpers

#=================================================
# STOP SERVICE
#=================================================
ynh_script_progression "Stopping Decypharr service for upgrade..."

ynh_systemctl --service="$app" --action="stop"

#=================================================
# INSTALL NEW BINARY
#=================================================
ynh_script_progression "Upgrading Decypharr binary..."

_binary=$(find "$YNH_APP_BUILDDIR/main/" -maxdepth 1 -type f -name "decypharr*" ! -name "*.md" ! -name "LICENSE" | head -1)
install -Dm755 "$_binary" "$install_dir/decypharr"

#=================================================
# UPDATE CONFIGURATION (preserves user edits via ynh_config_add)
#=================================================
ynh_script_progression "Updating system configurations..."

ynh_config_add_nginx
ynh_config_add_systemd
ynh_config_add_logrotate

# Only reconfigure config.json when upstream vars changed
# (user's debrid/arr config inside the file is managed via the web UI and should NOT be overwritten on upgrade)
# Re-render only server-level settings that come from YNH variables.
# We achieve this by using ynh_config_add with a partial template; see conf/config.json.

#=================================================
# START SERVICE
#=================================================
ynh_script_progression "Restarting Decypharr service..."

ynh_systemctl --service="$app" --action="start" --wait_until="listening on"

yunohost service add "$app" \
    --description="Debrid blackhole client" \
    --log="/var/log/$app/$app.log"

ynh_script_progression "Upgrade of Decypharr completed!"
