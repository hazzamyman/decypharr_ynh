#!/bin/bash

source _common.sh
source /usr/share/yunohost/helpers

#=================================================
# STOP SERVICE
#=================================================
ynh_script_progression --message="Stopping Decypharr service for upgrade..."

ynh_systemd_action --service_name="$app" --action="stop"

#=================================================
# UPGRADE THE BINARY
#=================================================
ynh_script_progression --message="Upgrading Decypharr binary..."

ynh_setup_source --dest_dir="$install_dir" --full_replace

chmod +x "$install_dir/decypharr"

#=================================================
# UPDATE SYSTEM CONFIGS
#=================================================
ynh_script_progression --message="Updating system configurations..."

ynh_add_nginx_config
ynh_add_systemd_config
ynh_use_logrotate

yunohost service add "$app" \
    --description="Debrid blackhole client" \
    --log="/var/log/$app/$app.log"

# NOTE: config.json is NOT re-rendered on upgrade to preserve user settings

#=================================================
# FUSE / MOUNT CONFIGURATION
#=================================================
mount_type=$(ynh_app_setting_get --app="$app" --key=mount_type)

if [ "$mount_type" != "none" ]; then
    ynh_script_progression --message="Verifying FUSE configuration..."
    
    # 1. Load FUSE kernel module - FAIL if not available
    if ! modprobe fuse 2>/dev/null; then
        ynh_die "FUSE kernel module could not be loaded. Your system kernel may not have FUSE support enabled or it is blocked. Streaming mode requires FUSE. Please try 'downloading' mode instead."
    fi
    
    # 2. Check /dev/fuse exists - FAIL if not available
    if [ ! -c /dev/fuse ]; then
        ynh_die "/dev/fuse does not exist. Your system does not support FUSE devices. Streaming mode requires FUSE. Please try 'downloading' mode instead."
    fi
    
    # 3. Persist FUSE module for boot
    if ! grep -q "^fuse$" /etc/modules 2>/dev/null; then
        echo "fuse" >> /etc/modules 2>/dev/null || true
    fi
    
    # 4. Configure fuse.conf with user_allow_other
    if ! grep -q "^user_allow_other" /etc/fuse.conf 2>/dev/null; then
        echo "user_allow_other" >> /etc/fuse.conf 2>/dev/null || true
    fi
    
    # 5. Add user to fuse group
    usermod -aG fuse "$app" 2>/dev/null || true
fi

#=================================================
# START SERVICE
#=================================================
ynh_script_progression --message="Restarting Decypharr service..."

ynh_systemd_action --service_name="$app" --action="start" --log_path="/var/log/$app/$app.log"

ynh_script_progression --message="Upgrade of $app completed!" --last
