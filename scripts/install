#!/bin/bash

source _common.sh
source /usr/share/yunohost/helpers

#=================================================
# INSTALL THE APP BINARY
#=================================================
ynh_script_progression "Installing Decypharr binary..."

# The resources system extracts the tarball directly into $install_dir.
# Find the binary regardless of exact filename (goreleaser may name it
# 'decypharr' or 'decypharr_Linux_x86_64' etc.)
_binary=$(find "$install_dir" -maxdepth 1 -type f -name "decypharr*" ! -name "*.md" ! -name "LICENSE" | head -1)

if [ -z "$_binary" ]; then
    ynh_die "Could not find decypharr binary in $install_dir"
fi

chmod 755 "$_binary"

# Rename to a fixed path so the systemd unit always works
if [ "$_binary" != "$install_dir/decypharr" ]; then
    mv "$_binary" "$install_dir/decypharr"
fi

#=================================================
# ADD A CONFIGURATION
#=================================================
ynh_script_progression "Generating configuration file..."

# Convert the 1/0 boolean from YunoHost args to JSON true/false
if [ "$download_uncached" = "1" ]; then
    download_uncached_json="true"
else
    download_uncached_json="false"
fi

# Set mount paths
if [ "$mount_type" != "none" ]; then
    mount_path="/mnt/decypharr"
    cache_dir="$data_dir/cache"
    mkdir -p "$mount_path" "$cache_dir"
    chown "$app:$app" "$mount_path" "$cache_dir"
else
    mount_path=""
    cache_dir="$data_dir/cache"
    mkdir -p "$cache_dir"
    chown "$app:$app" "$cache_dir"
fi

# Save settings for upgrade/restore scripts
ynh_app_setting_set --key=mount_path --value="$mount_path"
ynh_app_setting_set --key=cache_dir --value="$cache_dir"
ynh_app_setting_set --key=download_uncached_json --value="$download_uncached_json"

ynh_config_add --template="config.json" --destination="$data_dir/config.json"

chmod 600 "$data_dir/config.json"
chown "$app:$app" "$data_dir/config.json"

#=================================================
# SYSTEM CONFIGURATION
#=================================================
ynh_script_progression "Adding system configurations..."

ynh_config_add_nginx
ynh_config_add_systemd
ynh_config_add_logrotate

yunohost service add "$app" \
    --description="Debrid blackhole client" \
    --log="/var/log/$app/$app.log"

#=================================================
# FUSE / MOUNT PERMISSIONS
#=================================================
if [ "$mount_type" != "none" ]; then
    usermod -aG fuse "$app" 2>/dev/null || true
    if ! grep -q "^user_allow_other" /etc/fuse.conf 2>/dev/null; then
        echo "user_allow_other" >> /etc/fuse.conf
    fi
fi

#=================================================
# START SYSTEMD SERVICE
#=================================================
ynh_script_progression "Starting Decypharr service..."

ynh_systemctl --service="$app" --action="start"

ynh_script_progression "Installation of $app completed!"
