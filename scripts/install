#!/bin/bash
source _common.sh
source /usr/share/yunohost/helpers

#=================================================
# INSTALL THE APP BINARY
#=================================================
ynh_script_progression "Installing Decypharr binary..."

# The sources resource already downloaded and extracted the tarball.
# goreleaser typically names the binary 'decypharr' inside the archive,
# but handle the case where it might be 'decypharr_Linux_x86_64' etc.
_binary=$(find "$YNH_APP_BUILDDIR/main/" -maxdepth 1 -type f -name "decypharr*" ! -name "*.md" ! -name "LICENSE" | head -1)
install -Dm755 "$_binary" "$install_dir/decypharr"

#=================================================
# ADD A CONFIGURATION
#=================================================
ynh_script_progression "Generating configuration file..."

# Determine mount_path only when mounting is enabled
mount_path=""
cache_dir=""
if [ "$mount_type" != "none" ]; then
    mount_path="/mnt/decypharr"
    cache_dir="$data_dir/cache"
    mkdir -p "$mount_path" "$cache_dir"
    chown "$app:$app" "$mount_path" "$cache_dir"
fi

ynh_config_add --template="config.json" --destination="$data_dir/config.json"

#=================================================
# SYSTEM CONFIGURATION
#=================================================
ynh_script_progression "Adding system configurations..."

# NGINX reverse proxy
ynh_config_add_nginx

# Systemd service
ynh_config_add_systemd

yunohost service add "$app" \
    --description="Debrid blackhole client" \
    --log="/var/log/$app/$app.log"

# Logrotate
ynh_config_add_logrotate

#=================================================
# FUSE / mount permissions (only when mounting)
#=================================================
if [ "$mount_type" != "none" ]; then
    # Allow the app user to use FUSE
    usermod -aG fuse "$app" 2>/dev/null || true

    # allow_other in /etc/fuse.conf
    if ! grep -q "^user_allow_other" /etc/fuse.conf 2>/dev/null; then
        echo "user_allow_other" >> /etc/fuse.conf
    fi
fi

#=================================================
# START SYSTEMD SERVICE
#=================================================
ynh_script_progression "Starting Decypharr service..."

ynh_systemctl --service="$app" --action="start" --wait_until="listening on"

ynh_script_progression "Installation of Decypharr completed!"
