#!/bin/bash

source _common.sh
source /usr/share/yunohost/helpers

#=================================================
# DOWNLOAD AND INSTALL THE APP BINARY
#=================================================
ynh_script_progression --message="Installing Decypharr binary..."

ynh_setup_source --dest_dir="$install_dir"

chmod +x "$install_dir/decypharr"

#=================================================
# ADD A CONFIGURATION
#=================================================
ynh_script_progression --message="Generating configuration file..."

# YunoHost passes booleans as 1/0 — convert to JSON true/false
if [ "$download_uncached" = "1" ]; then
    download_uncached_json="true"
else
    download_uncached_json="false"
fi

# Set mount paths
if [ "$mount_type" != "none" ]; then
    mount_path="/mnt/decypharr"
    cache_dir="$data_dir/cache"
    mkdir -p "$mount_path" "$cache_dir"
    chown "$app:$app" "$mount_path" "$cache_dir"
else
    mount_path=""
    cache_dir="$data_dir/cache"
    mkdir -p "$cache_dir"
    chown "$app:$app" "$cache_dir"
fi

ynh_app_setting_set --app="$app" --key=mount_path --value="$mount_path"
ynh_app_setting_set --app="$app" --key=cache_dir --value="$cache_dir"
ynh_app_setting_set --app="$app" --key=download_uncached_json --value="$download_uncached_json"
ynh_app_setting_set --app="$app" --key=mount_type --value="$mount_type"

ynh_add_config --template="config.json" --destination="$data_dir/config.json"

chmod 600 "$data_dir/config.json"
chown "$app:$app" "$data_dir/config.json"

#=================================================
# SYSTEM CONFIGURATION
#=================================================
ynh_script_progression --message="Adding system configurations..."

ynh_add_nginx_config
ynh_add_systemd_config
ynh_use_logrotate

yunohost service add "$app" \
    --description="Debrid blackhole client" \
    --log="/var/log/$app/$app.log"

#=================================================
# FUSE / MOUNT PERMISSIONS
#=================================================
if [ "$mount_type" != "none" ]; then
    usermod -aG fuse "$app" 2>/dev/null || true
    if ! grep -q "^user_allow_other" /etc/fuse.conf 2>/dev/null; then
        echo "user_allow_other" >> /etc/fuse.conf
    fi
fi

#=================================================
# START SYSTEMD SERVICE
#=================================================
ynh_script_progression --message="Starting Decypharr service..."

ynh_systemd_action --service_name="$app" --action="start" --log_path="/var/log/$app/$app.log"

ynh_script_progression --message="Installation of $app completed!" --last
