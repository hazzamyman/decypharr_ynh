{
  "bind_address": "127.0.0.1",
  "port": "__PORT__",
  "url_base": "__PATH__",
  "app_url": "https://__DOMAIN____PATH__",
  "log_level": "__LOG_LEVEL__",
  "use_auth": true,
  "username": "admin",
  "password": "",
  "api_token": "",
  "debrids": [],
  "qbittorrent": {
    "download_folder": "__DATA_DIR__/downloads",
    "categories": ["sonarr", "radarr", "lidarr", "readarr", "whisparr"]
  },
  "mount": {
    "type": "__MOUNT_TYPE__",
    "mount_path": "__MOUNT_PATH__",
    "dfs": {
      "cache_dir": "__CACHE_DIR__",
      "chunk_size": "__DFS_CHUNK_SIZE__",
      "disk_cache_size": "__DFS_DISK_CACHE_SIZE__",
      "cache_expiry": "__DFS_CACHE_EXPIRY__",
      "cache_cleanup_interval": "10m",
      "allow_other": true,
      "default_permissions": true
    },
    "rclone": {
      "cache_dir": "__CACHE_DIR__",
      "vfs_cache_mode": "writes",
      "vfs_cache_max_size": "0",
      "vfs_read_chunk_size": "128MB",
      "buffer_size": "16MB",
      "transfers": 4
    }
  },
  "repair": {
    "enabled": false,
    "interval": "30m",
    "auto_process": false,
    "workers": 2,
    "strategy": "per_file"
  },
  "arrs": []
}
