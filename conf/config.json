{
  "bind_address": "127.0.0.1",
  "port": "__PORT__",
  "url_base": "__PATH__",
  "app_url": "https://__DOMAIN____PATH__",
  "log_level": "__LOG_LEVEL__",
  "use_auth": true,
  "username": "admin",
  "password": "",
  "api_token": "",
  "debrids": [
    {
      "provider": "__DEBRID_PROVIDER__",
      "name": "Primary",
      "api_key": "__DEBRID_API_KEY__",
      "download_uncached": __DOWNLOAD_UNCACHED_JSON__,
      "rate_limit": "200/minute",
      "workers": 50,
      "minimum_free_slot": 0,
      "limit": 0,
      "torrents_refresh_interval": "5m",
      "download_links_refresh_interval": "10m",
      "auto_expire_links_after": "24h",
      "proxy": "",
      "unpack_rar": true
    }
  ],
  "mount": {
    "type": "__MOUNT_TYPE__",
    "mount_path": "__MOUNT_PATH__",
    "dfs": {
      "cache_dir": "__CACHE_DIR__",
      "chunk_size": "10MB",
      "disk_cache_size": "0",
      "cache_expiry": "1h",
      "cache_cleanup_interval": "10m",
      "allow_other": true,
      "default_permissions": true
    },
    "rclone": {
      "cache_dir": "__CACHE_DIR__",
      "vfs_cache_mode": "writes",
      "vfs_cache_max_size": "0",
      "vfs_read_chunk_size": "128MB",
      "buffer_size": "16MB",
      "transfers": 4
    }
  },
  "repair": {
    "enabled": false,
    "interval": "30m",
    "auto_process": false,
    "workers": 2,
    "strategy": "per_file"
  },
  "arrs": []
}
